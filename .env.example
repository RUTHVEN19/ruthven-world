# Flask
FLASK_SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# FAL AI - Get your key from https://fal.ai/dashboard/keys
FAL_KEY=

# Pinata (IPFS) - Get keys from https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# Ethereum - NEVER commit real private keys!
# Use a dedicated deployer wallet, not your main wallet
DEPLOYER_PRIVATE_KEY=
OWNER_ADDRESS=

# Infura RPC - Get key from https://app.infura.io
INFURA_API_KEY=

# Etherscan - For contract verification https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Optional: Custom RPC URLs (overrides Infura)
# SEPOLIA_RPC_URL=
# MAINNET_RPC_URL=
